<!DOCTYPE html>
<html lang="zh-Hant">

<head>

<meta charset="UTF-8">

<meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
>

<title>修改訂單｜卡哩共好</title>

<meta
    name="description"
    content="修改訂單"
>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:"Noto Sans TC",sans-serif;
    background:#FAF8F3;
    color:#333;
    line-height:1.8;
}

.container{
    max-width:800px;
    margin:auto;
    padding:24px;
}

.back-link{

    display:inline-flex;
    align-items:center;
    justify-content:center;

    width:48px;
    height:48px;

    border:1px solid #D8D2C8;
    border-radius:50%;

    text-decoration:none;

    color:#3E2F24;

    font-size:22px;

    margin-bottom:24px;

    background:#FFF;

}

.back-link:hover{
    background:#F4F1EA;
}

h1{
    color:#3E2F24;
    margin-bottom:24px;
    font-size:32px;
}

.form-wrapper{

    background:#FFF;

    padding:32px;

    border-radius:16px;

    box-shadow:0 5px 20px rgba(0,0,0,0.05);

}

.form-group{
    margin-bottom:22px;
}

label{
    display:block;
    margin-bottom:8px;
    font-weight:600;
    color:#3E2F24;
}

input,
select,
textarea{

    width:100%;

    padding:12px 14px;

    border:1px solid #D8D2C8;

    border-radius:10px;

    font-size:16px;

    background:#FFF;

}

textarea{
    min-height:120px;
    resize:vertical;
}

.section-title{

    margin-top:32px;
    margin-bottom:16px;

    font-size:20px;
    font-weight:700;

    color:#3E2F24;

}

.submit-btn{

    width:100%;

    margin-top:20px;

    padding:16px;

    border:none;

    border-radius:12px;

    background:#C89B3C;

    color:#FFF;

    font-size:18px;

    font-weight:700;

    cursor:pointer;

}

.submit-btn:hover{
    opacity:0.9;
}

.hidden{
    display:none;
}
</style>

</head>

<body>

<div class="container">

    <a
        href="order-query.html"
        class="back-link"
    >
        ←
    </a>

    <h1>修改訂單</h1>

    <div class="form-wrapper">

        <form id="editForm">

            <input
                type="hidden"
                id="order_id"
            >

            <div id="formContent">

            </div>

            <button
                type="submit"
                class="submit-btn"
            >
                儲存修改
            </button>

        </form>

    </div>

</div>

<script>

const WEB_APP_URL =
"https://script.google.com/macros/s/AKfycbydkuYYK9nokEHeazKTrYQhvxjl_vmN1QaVS1PwVU-uiC0sC-C3cN4u9ZxEpL_Ax7aK/exec";

const urlParams =
new URLSearchParams(
    window.location.search
);

const orderId =
    urlParams.get("order_id");

console.log(
  window.location.href
);

console.log(
  "orderId=",
  orderId
);

let currentOrder = null;

function renderPersonalForm() {

    document
    .getElementById("formContent")
    .innerHTML = `

    <div class="section-title">
        基本資料
    </div>

    <div class="form-group">
        <label>姓名</label>
        <input id="name"
        value="${currentOrder.name || ""}">
    </div>

    <div class="form-group">
        <label>手機</label>
        <input id="phone"
        value="0${currentOrder.phone || ""}">
    </div>

    <div class="form-group">
        <label>LINE 名稱</label>
        <input id="line_name"
        value="${currentOrder.line_name || ""}">
    </div>

    <div class="form-group">
        <label>來源</label>
        <input id="Source"
        value="${currentOrder.Source || ""}">
    </div>

    <div class="form-group">
        <label>首次購買</label>
        <input id="First_Purchase"
        value="${currentOrder.First_Purchase || ""}">
    </div>

    <div class="section-title">
        取餐資訊
    </div>

    <div class="form-group">
        <label>取餐日期</label>
        <input type="date"
        id="pickup_date">
    </div>

    <div class="form-group">
        <label>取餐時間</label>
        <input id="pickup_time"
        value="${currentOrder.pickup_time || ""}">
    </div>

    <div class="form-group">
        <label>取餐據點</label>
        <input id="pickup_node"
        value="${currentOrder.pickup_node || ""}">
    </div>

    <div class="form-group">
        <label>配送地址</label>
        <textarea
            id="delivery_address"
        >${currentOrder.delivery_address || ""}</textarea>
    </div>

    <div class="section-title">
        餐點
    </div>

    <div class="form-group">
        <label>豬排咖哩</label>
        <input type="number"
        id="pork_qty"
        value="${currentOrder.pork_qty || 0}">
    </div>

    <div class="form-group">
        <label>雞腿咖哩</label>
        <input type="number"
        id="chicken_qty"
        value="${currentOrder.chicken_qty || 0}">
    </div>

    <div class="form-group">
        <label>本日限定</label>
        <input type="number"
        id="daily_qty"
        value="${currentOrder.daily_qty || 0}">
    </div>

    <div class="form-group">
        <label>付款方式</label>
        <input id="payment_method"
        value="${currentOrder.payment_method || ""}">
    </div>

    <div class="form-group">
        <label>備註</label>
        <textarea id="remark">${currentOrder.remark || ""}</textarea>
    </div>

    `;

    const date =
    new Date(
        currentOrder.pickup_date
    );

    document
    .getElementById("pickup_date")
    .value =
    date.toISOString()
    .split("T")[0];

}

function renderGroupForm() {

    document
    .getElementById("formContent")
    .innerHTML = `

    <div class="section-title">
        團購聯絡資料
    </div>

    <div class="form-group">
        <label>公司名稱</label>
        <input id="company_name"
        value="${currentOrder.company_name || ""}">
    </div>

    <div class="form-group">
        <label>聯絡人</label>
        <input id="contact_name"
        value="${currentOrder.contact_name || ""}">
    </div>

    <div class="form-group">
        <label>手機</label>
        <input id="phone"
        value="0${currentOrder.phone || ""}">
    </div>

    <div class="form-group">
        <label>LINE 名稱</label>
        <input id="line_name"
        value="${currentOrder.line_name || ""}">
    </div>

    <div class="form-group">
        <label>Decision Maker</label>
        <input id="Decision_Maker"
        value="${currentOrder.Decision_Maker || ""}">
    </div>

    <div class="form-group">
        <label>來源</label>
        <input id="Source"
        value="${currentOrder.Source || ""}">
    </div>

    <div class="form-group">
        <label>首次團購</label>
        <input id="First_Purchase"
        value="${currentOrder.First_Purchase || ""}">
    </div>

    <div class="section-title">
        取餐資訊
    </div>

    <div class="form-group">
        <label>取餐日期</label>
        <input type="date"
        id="pickup_date">
    </div>

    <div class="form-group">
        <label>取餐時間</label>
        <input id="pickup_time"
        value="${currentOrder.pickup_time || ""}">
    </div>

    <div class="form-group">
        <label>取餐據點</label>
        <input id="pickup_node"
        value="${currentOrder.pickup_node || ""}">
    </div>

    <div class="form-group">
        <label>配送地址</label>
        <textarea
            id="delivery_address"
        >${currentOrder.delivery_address || ""}</textarea>
    </div>

    <div class="section-title">
        餐點
    </div>

    <div class="form-group">
        <label>豬排咖哩</label>
        <input type="number"
        id="pork_qty"
        value="${currentOrder.pork_qty || 0}">
    </div>

    <div class="form-group">
        <label>雞腿咖哩</label>
        <input type="number"
        id="chicken_qty"
        value="${currentOrder.chicken_qty || 0}">
    </div>

    <div class="form-group">
        <label>本日限定</label>
        <input type="number"
        id="daily_qty"
        value="${currentOrder.daily_qty || 0}">
    </div>

    <div class="form-group">
        <label>付款方式</label>
        <input id="payment_method"
        value="${currentOrder.payment_method || ""}">
    </div>

    <div class="form-group">
        <label>備註</label>
        <textarea id="remark">${currentOrder.remark || ""}</textarea>
    </div>

    `;

    const date =
    new Date(
        currentOrder.pickup_date
    );

    document
    .getElementById("pickup_date")
    .value =
    date.toISOString()
    .split("T")[0];

}

function renderEnterpriseForm() {

    document
    .getElementById("formContent")
    .innerHTML = `

    <div class="section-title">
        企業體驗聯絡資料
    </div>

    <div class="form-group">
        <label>公司名稱</label>
        <input id="company_name"
        value="${currentOrder.company_name || ""}">
    </div>

    <div class="form-group">
        <label>聯絡人</label>
        <input id="contact_name"
        value="${currentOrder.contact_name || ""}">
    </div>

    <div class="form-group">
        <label>手機</label>
        <input id="phone"
        value="0${currentOrder.phone || ""}">
    </div>

    <div class="form-group">
        <label>LINE 名稱</label>
        <input id="line_name"
        value="${currentOrder.line_name || ""}">
    </div>

    <div class="form-group">
        <label>Decision Maker</label>
        <input id="Decision_Maker"
        value="${currentOrder.Decision_Maker || ""}">
    </div>

    <div class="form-group">
        <label>來源</label>
        <input id="Source"
        value="${currentOrder.Source || ""}">
    </div>

    <div class="section-title">
        取餐資訊
    </div>

    <div class="form-group">
        <label>取餐日期</label>
        <input
            type="date"
            id="pickup_date"
        >
    </div>

    <div class="form-group">
        <label>取餐時間</label>
        <input
            id="pickup_time"
            value="${currentOrder.pickup_time || ""}"
        >
    </div>

    <div class="form-group">
        <label>取餐據點</label>
        <input
            id="pickup_node"
            value="${currentOrder.pickup_node || ""}"
        >
    </div>

    <div class="form-group">
        <label>配送地址</label>
        <textarea
            id="delivery_address"
        >${currentOrder.delivery_address || ""}</textarea>
    </div>

    <div class="form-group">
        <label>備註</label>
        <textarea
            id="remark"
        >${currentOrder.remark || ""}</textarea>
    </div>

    `;

    const date =
    new Date(
        currentOrder.pickup_date
    );

    document
    .getElementById("pickup_date")
    .value =
    date.toISOString()
    .split("T")[0];

}

async function loadOrder() {

    if (!orderId) {

        alert("缺少訂單編號");

        return;

    }

    try {

        const response =
        await fetch(

            WEB_APP_URL +
            "?action=queryOrderById&order_id=" +
            encodeURIComponent(orderId)

        );

        const result =
        await response.json();

        if (!result.order) {

            alert("查無訂單");

            return;

        }

        currentOrder =
        result.order;

        document
        .getElementById("order_id")
        .value =
        currentOrder.order_id;

        if (
            currentOrder.order_type ===
            "personal"
        ) {

            renderPersonalForm();

        }

        else if (
            currentOrder.order_type ===
            "group"
        ) {

            renderGroupForm();

        }

        else if (
            currentOrder.order_type ===
            "enterprise"
        ) {

            renderEnterpriseForm();

        }

    }
    catch(error) {

        console.error(error);

        alert("載入失敗");

    }

}

async function saveOrder(e) {

    e.preventDefault();

    try {

        const params =
        new URLSearchParams();

        params.append(
            "action",
            "updateOrder"
        );

        params.append(
            "order_id",
            document
            .getElementById("order_id")
            .value
        );

        params.append(
            "name",
            document
            .getElementById("name")
            ?.value || ""
        );

        params.append(
            "phone",
            document
            .getElementById("phone")
            ?.value.replace(/^0/,"") || ""
        );

        params.append(
            "line_name",
            document
            .getElementById("line_name")
            ?.value || ""
        );

        params.append(
            "company_name",
            document
            .getElementById("company_name")
            ?.value || ""
        );

        params.append(
            "contact_name",
            document
            .getElementById("contact_name")
            ?.value || ""
        );

        params.append(
            "pickup_date",
            document
            .getElementById("pickup_date")
            ?.value || ""
        );

        params.append(
            "pickup_time",
            document
            .getElementById("pickup_time")
            ?.value || ""
        );

        params.append(
            "pickup_node",
            document
            .getElementById("pickup_node")
            ?.value || ""
        );

        params.append(
            "delivery_address",
            document
            .getElementById("delivery_address")
            ?.value || ""
        );

        params.append(
            "pork_qty",
            document
            .getElementById("pork_qty")
            ?.value || 0
        );

        params.append(
            "chicken_qty",
            document
            .getElementById("chicken_qty")
            ?.value || 0
        );

        params.append(
            "daily_qty",
            document
            .getElementById("daily_qty")
            ?.value || 0
        );

        params.append(
            "payment_method",
            document
            .getElementById("payment_method")
            ?.value || ""
        );

        params.append(
            "Decision_Maker",
            document
            .getElementById("Decision_Maker")
            ?.value || ""
        );

        params.append(
            "Source",
            document
            .getElementById("Source")
            ?.value || ""
        );

        params.append(
            "First_Purchase",
            document
            .getElementById("First_Purchase")
            ?.value || ""
        );

        params.append(
            "remark",
            document
            .getElementById("remark")
            ?.value || ""
        );

        const response =
        await fetch(

            WEB_APP_URL +
            "?" +
            params.toString()

        );

        const result =
        await response.json();

        if (result.success) {

            alert(
                "訂單修改成功"
            );

            window.location.href =
            "order-query.html";

        }
        else {

            alert(
                "修改失敗"
            );

        }

    }
    catch(error) {

        console.error(error);

        alert(
            "系統發生錯誤"
        );

    }

}

document
.getElementById("editForm")
.addEventListener(
    "submit",
    saveOrder
);

loadOrder();

</script>

</body>

</html>
